<button class="lang-toggle" type="button" data-lang-toggle aria-label="Switch language">
  <span class="lang-toggle__label lang-toggle__label--en">EN</span>
  <span class="lang-toggle__label lang-toggle__label--zh">中文</span>
  <span class="lang-toggle__label lang-toggle__label--ja">日本語</span>
  <span class="lang-toggle__thumb" aria-hidden="true"></span>
</button>

<script is:inline>
  const LANG_KEY = 'opendex-lang';
  const LANGS = ['en', 'zh', 'ja'];
  const LANG_MAP = { en: 'en', zh: 'zh-CN', ja: 'ja' };

  function updateLangToggleState() {
    const root = document.documentElement;
    const lang = root.dataset.lang || 'en';

    document.querySelectorAll('[data-lang-toggle]').forEach(function(button) {
      button.setAttribute('aria-label',
        lang === 'zh' ? '切换语言' :
        lang === 'ja' ? '言語を切り替え' :
        'Switch language'
      );
    });
  }

  function setLang(lang) {
    var root = document.documentElement;
    var storageKey = root.dataset.langStorageKey || LANG_KEY;
    root.dataset.lang = lang;
    root.setAttribute('lang', LANG_MAP[lang] || 'en');
    try {
      localStorage.setItem(storageKey, lang);
    } catch(e) {
      // Ignore storage errors in restricted environments.
    }
    updateLangToggleState();
  }

  function initLangToggle() {
    document.querySelectorAll('[data-lang-toggle]').forEach(function(button) {
      if (button.dataset.langBound === 'true') return;
      button.dataset.langBound = 'true';
      button.addEventListener('click', function(e) {
        var rect = button.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var segW = rect.width / 3;
        var current = document.documentElement.dataset.lang || 'en';

        // If click is in a specific segment, go directly there
        if (x < segW) {
          setLang('en');
        } else if (x < segW * 2) {
          setLang('zh');
        } else {
          setLang('ja');
        }
      });
    });
    updateLangToggleState();
  }

  initLangToggle();
  document.addEventListener('astro:page-load', initLangToggle);
</script>

<style>
  .lang-toggle {
    position: relative;
    width: 156px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0;
    border-radius: 999px;
    border: 1px solid var(--c-border);
    background:
      linear-gradient(120deg, var(--surface-glass-a), var(--surface-glass-b));
    padding: 0 0.3rem;
    color: var(--c-text-muted);
    cursor: pointer;
    user-select: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    box-shadow: inset 0 1px 0 var(--surface-highlight);
  }

  .lang-toggle:hover {
    border-color: color-mix(in srgb, var(--c-accent) 55%, var(--c-border) 45%);
    box-shadow:
      inset 0 1px 0 var(--surface-highlight),
      0 0 22px -14px var(--c-glow);
  }

  .lang-toggle__label {
    position: relative;
    z-index: 2;
    width: 33.333%;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    pointer-events: none;
    transition: color 0.25s, opacity 0.25s;
    opacity: 0.72;
    color: var(--c-text-muted);
  }

  .lang-toggle__label--en {
    color: var(--c-text);
    opacity: 1;
  }

  .lang-toggle__thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: calc(33.333% - 4px);
    height: 28px;
    border-radius: 999px;
    background:
      linear-gradient(120deg, rgba(0, 182, 255, 0.22), rgba(255, 95, 134, 0.24));
    border: 1px solid color-mix(in srgb, var(--c-accent) 45%, var(--c-border) 55%);
    box-shadow:
      0 8px 16px -14px var(--c-shadow),
      0 0 20px -14px var(--c-glow);
    transition: transform 0.38s var(--ease-out-expo), background 0.35s;
  }

  /* Chinese active */
  :root[data-lang='zh'] .lang-toggle__thumb {
    transform: translateX(calc(100% + 2px));
    background:
      linear-gradient(120deg, rgba(103, 215, 255, 0.18), rgba(255, 158, 195, 0.28));
  }

  :root[data-lang='zh'] .lang-toggle__label--en {
    opacity: 0.72;
    color: var(--c-text-muted);
  }

  :root[data-lang='zh'] .lang-toggle__label--zh {
    color: var(--c-text);
    opacity: 1;
  }

  /* Japanese active */
  :root[data-lang='ja'] .lang-toggle__thumb {
    transform: translateX(calc(200% + 4px));
    background:
      linear-gradient(120deg, rgba(103, 215, 255, 0.18), rgba(255, 158, 195, 0.28));
  }

  :root[data-lang='ja'] .lang-toggle__label--en {
    opacity: 0.72;
    color: var(--c-text-muted);
  }

  :root[data-lang='ja'] .lang-toggle__label--ja {
    color: var(--c-text);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .lang-toggle {
      width: 144px;
      height: 34px;
    }

    .lang-toggle__thumb {
      height: 26px;
    }
  }
</style>
