---
import { withBase } from '@/lib/withBase';
import ThemeToggle from '@/components/ThemeToggle.astro';
import LangToggle from '@/components/LangToggle.astro';

const links = [
  { en: 'Works', zh: '作品', ja: '作品集', href: withBase('/works') },
  { en: 'Travelogue', zh: '游记', ja: '旅行記', href: withBase('/travelogue') },
  { en: 'About', zh: '关于', ja: '概要', href: withBase('/about') },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav__inner container">
    <a href={withBase('/')} class="nav__logo">Yanming Shao</a>
    <div class="nav__controls">
      <ul class="nav__links">
        {links.map(({ en, zh, ja, href }) => (
          <li>
            <a
              href={href}
              class:list={['nav__link', { active: currentPath.startsWith(href) && href !== withBase('/') }]}
            >
              <span data-lang-en>{en}</span><span data-lang-zh>{zh}</span><span data-lang-ja>{ja}</span>
            </a>
          </li>
        ))}
      </ul>
      <LangToggle />
      <ThemeToggle />
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
    background:
      linear-gradient(180deg, rgba(15, 16, 18, 0.82), rgba(15, 16, 18, 0.7));
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 12px 30px -24px rgba(0, 0, 0, 0.45),
      inset 0 -1px 0 rgba(255, 255, 255, 0.04);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.75rem;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.35rem;
    letter-spacing: 0.02em;
    transition: color 0.25s, text-shadow 0.25s;
    color: #f0e8df;
  }

  .nav__logo:hover {
    color: #fff8ef;
  }

  .nav__links {
    display: flex;
    gap: 0.4rem;
    list-style: none;
  }

  .nav__controls {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .nav__link {
    font-size: 0.78rem;
    font-weight: 500;
    color: #171717;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.25s, border-color 0.25s, background-color 0.25s;
    padding: 0.32rem 0.68rem;
    background: rgba(246, 241, 233, 0.94);
    border: 1px solid rgba(105, 93, 78, 0.2);
    box-shadow: 0 6px 12px -12px rgba(0, 0, 0, 0.6);
  }

  .nav__link:hover {
    color: #0f0f0f;
    border-color: rgba(128, 48, 43, 0.28);
    background: rgba(251, 246, 239, 0.96);
  }

  .nav__link.active {
    color: #f3ece3;
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(23, 24, 27, 0.92);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 640px) {
    .nav__inner {
      height: auto;
      padding-top: 0.7rem;
      padding-bottom: 0.7rem;
      gap: 0.75rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .nav__controls {
      width: 100%;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .nav__links {
      flex: 1;
      justify-content: flex-start;
    }
  }
</style>
