---
import { withBase } from '@/lib/withBase';
---

<div class="music-player" id="music-player" data-music-player>
  <audio id="music-audio" loop preload="auto" autoplay playsinline>
    <source src={withBase('/audio/lake.m4a')} type="audio/mp4" />
  </audio>

  <button class="music-player__toggle" id="music-toggle" type="button" aria-label="Play music">
    <span class="music-player__eq" id="music-eq" aria-hidden="true">
      <span class="music-player__bar"></span>
      <span class="music-player__bar"></span>
      <span class="music-player__bar"></span>
      <span class="music-player__bar"></span>
    </span>
  </button>

  <div class="music-player__info">
    <span class="music-player__title">
      <span data-lang-en>Lake</span><span data-lang-zh>湖畔</span><span data-lang-ja>湖</span>
    </span>
  </div>

  <input
    type="range"
    class="music-player__volume"
    id="music-volume"
    min="0"
    max="1"
    step="0.05"
    value="0.5"
    aria-label="Volume"
  />
</div>

<script is:inline>
  const MUSIC_KEY = 'opendex-music-playing';
  const VOLUME_KEY = 'opendex-music-volume';

  function initMusicPlayer() {
    var player = document.getElementById('music-player');
    var audio = document.getElementById('music-audio');
    var toggle = document.getElementById('music-toggle');
    var volumeSlider = document.getElementById('music-volume');
    var eq = document.getElementById('music-eq');

    if (!player || !audio || !toggle || !volumeSlider || !eq) return;
    if (toggle.dataset.musicBound === 'true') return;
    toggle.dataset.musicBound = 'true';

    var resumeEvents = ['pointerdown', 'keydown', 'touchstart'];

    try {
      var savedVol = localStorage.getItem(VOLUME_KEY);
      if (savedVol !== null) {
        audio.volume = parseFloat(savedVol);
        volumeSlider.value = savedVol;
      } else {
        audio.volume = 0.35;
        volumeSlider.value = '0.35';
      }
    } catch(e) {}

    function syncUi(playing) {
      player.classList.toggle('is-playing', playing);
      eq.classList.toggle('is-animating', playing);
      toggle.setAttribute('aria-label', playing ? 'Pause music' : 'Play music');
    }

    function removeResumeListeners() {
      resumeEvents.forEach(function(eventName) {
        window.removeEventListener(eventName, resumeAfterInteraction);
      });
    }

    function resumeAfterInteraction() {
      removeResumeListeners();
      setPlaying(true);
    }

    function armAutoplayFallback() {
      removeResumeListeners();
      resumeEvents.forEach(function(eventName) {
        window.addEventListener(eventName, resumeAfterInteraction, { once: true, passive: true });
      });
    }

    function setPlaying(playing) {
      if (playing) {
        audio.play().then(function() {
          syncUi(true);
          try { localStorage.setItem(MUSIC_KEY, 'true'); } catch(e) {}
        }).catch(function() {
          syncUi(false);
          armAutoplayFallback();
        });
      } else {
        audio.pause();
        syncUi(false);
        try { localStorage.setItem(MUSIC_KEY, 'false'); } catch(e) {}
      }
    }

    toggle.addEventListener('click', function() {
      setPlaying(audio.paused);
    });

    volumeSlider.addEventListener('input', function() {
      audio.volume = parseFloat(volumeSlider.value);
      try { localStorage.setItem(VOLUME_KEY, volumeSlider.value); } catch(e) {}
    });

    syncUi(false);

    try {
      if (localStorage.getItem(MUSIC_KEY) !== 'false') {
        setPlaying(true);
      }
    } catch(e) {
      setPlaying(true);
    }
  }

  initMusicPlayer();
  document.addEventListener('astro:page-load', initMusicPlayer);
</script>

<style>
  .music-player {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.65rem 0.45rem 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(15, 16, 18, 0.92), rgba(20, 20, 23, 0.9));
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
    box-shadow:
      0 18px 30px -16px rgba(0, 0, 0, 0.56),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: border-color 0.25s, box-shadow 0.25s, opacity 0.3s;
    opacity: 0.94;
  }

  .music-player:hover {
    opacity: 1;
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 20px 34px -14px rgba(0, 0, 0, 0.62),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* Toggle button */
  .music-player__toggle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(135deg, rgba(119, 47, 44, 0.94), rgba(176, 106, 79, 0.86));
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.25s, box-shadow 0.25s;
  }

  .music-player__toggle:hover {
    box-shadow: 0 0 16px -8px rgba(176, 106, 79, 0.5);
  }

  /* Equalizer bars */
  .music-player__eq {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 14px;
  }

  .music-player__bar {
    width: 3px;
    background: linear-gradient(180deg, var(--c-accent), var(--c-accent-2));
    border-radius: 1px;
    height: 4px;
    transition: height 0.2s;
  }

  .music-player__bar:nth-child(1) { height: 6px; }
  .music-player__bar:nth-child(2) { height: 4px; }
  .music-player__bar:nth-child(3) { height: 8px; }
  .music-player__bar:nth-child(4) { height: 5px; }

  .music-player__eq.is-animating .music-player__bar {
    animation: eq-bounce 0.8s ease-in-out infinite alternate;
  }

  .music-player__eq.is-animating .music-player__bar:nth-child(1) {
    animation-delay: 0s;
  }

  .music-player__eq.is-animating .music-player__bar:nth-child(2) {
    animation-delay: 0.15s;
  }

  .music-player__eq.is-animating .music-player__bar:nth-child(3) {
    animation-delay: 0.3s;
  }

  .music-player__eq.is-animating .music-player__bar:nth-child(4) {
    animation-delay: 0.45s;
  }

  @keyframes eq-bounce {
    0% { height: 3px; }
    100% { height: 14px; }
  }

  /* Track title */
  .music-player__info {
    display: flex;
    flex-direction: column;
  }

  .music-player__title {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ece2d6;
    white-space: nowrap;
  }

  /* Volume slider */
  .music-player__volume {
    width: 52px;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: rgba(255, 255, 255, 0.16);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .music-player__volume::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: linear-gradient(135deg, #d3c0ad, #fff4e7);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 0 8px -2px rgba(255, 255, 255, 0.18);
    cursor: pointer;
  }

  .music-player__volume::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: linear-gradient(135deg, #d3c0ad, #fff4e7);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 0 8px -2px rgba(255, 255, 255, 0.18);
    cursor: pointer;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .music-player {
      bottom: 1rem;
      right: 1rem;
      padding: 0.4rem 0.55rem 0.4rem 0.45rem;
      gap: 0.4rem;
    }

    .music-player__info {
      display: none;
    }

    .music-player__volume {
      width: 40px;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .music-player__eq.is-animating .music-player__bar {
      animation: none;
    }

    .music-player__eq.is-animating .music-player__bar:nth-child(1) { height: 10px; }
    .music-player__eq.is-animating .music-player__bar:nth-child(2) { height: 8px; }
    .music-player__eq.is-animating .music-player__bar:nth-child(3) { height: 12px; }
    .music-player__eq.is-animating .music-player__bar:nth-child(4) { height: 9px; }
  }
</style>
