<button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to night mode">
  <span class="theme-toggle__label theme-toggle__label--day"><span data-lang-en>Day</span><span data-lang-zh>日间</span><span data-lang-ja>昼</span></span>
  <span class="theme-toggle__label theme-toggle__label--night"><span data-lang-en>Night</span><span data-lang-zh>夜间</span><span data-lang-ja>夜</span></span>
  <span class="theme-toggle__thumb" aria-hidden="true"></span>
</button>

<script is:inline>
  const THEME_KEY = 'opendex-theme';
  const THEME_TRANSITION_MS = 300;
  let themeTransitionTimer;

  function updateThemeToggleState() {
    const root = document.documentElement;
    const isNight = root.dataset.theme === 'night';
    var lang = root.dataset.lang || 'en';

    document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
      button.setAttribute('aria-pressed', String(isNight));
      if (lang === 'zh') {
        button.setAttribute('aria-label', isNight ? '切换为日间模式' : '切换为夜间模式');
      } else if (lang === 'ja') {
        button.setAttribute('aria-label', isNight ? '昼モードに切替' : '夜モードに切替');
      } else {
        button.setAttribute('aria-label', isNight ? 'Switch to day mode' : 'Switch to night mode');
      }
    });
  }

  function setTheme(nextTheme) {
    const root = document.documentElement;
    root.dataset.themeSwitching = 'true';
    clearTimeout(themeTransitionTimer);
    root.dataset.theme = nextTheme;
    themeTransitionTimer = window.setTimeout(() => {
      delete root.dataset.themeSwitching;
    }, THEME_TRANSITION_MS);
    try {
      localStorage.setItem(THEME_KEY, nextTheme);
    } catch {
      // Ignore storage errors in restricted environments.
    }
    updateThemeToggleState();
  }

  function initThemeToggle() {
    document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
      if (button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme === 'night' ? 'night' : 'day';
        setTheme(current === 'night' ? 'day' : 'night');
      });
    });
    updateThemeToggleState();
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>

<style>
  .theme-toggle {
    position: relative;
    width: 136px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    border-radius: 999px;
    border: 1px solid var(--c-border);
    background:
      linear-gradient(120deg, var(--surface-glass-a), var(--surface-glass-b));
    padding: 0 0.5rem;
    color: var(--c-text-muted);
    cursor: pointer;
    user-select: none;
    transition: border-color 0.25s, box-shadow 0.25s;
    box-shadow: inset 0 1px 0 var(--surface-highlight);
  }

  .theme-toggle:hover {
    border-color: color-mix(in srgb, var(--c-accent) 55%, var(--c-border) 45%);
    box-shadow:
      inset 0 1px 0 var(--surface-highlight),
      0 0 22px -14px var(--c-glow);
  }

  .theme-toggle__label {
    position: relative;
    z-index: 2;
    width: 50%;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
    transition: color 0.25s, opacity 0.25s;
  }

  .theme-toggle__label--day {
    color: var(--c-text);
  }

  .theme-toggle__label--night {
    opacity: 0.72;
  }

  .theme-toggle__thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: calc(50% - 5px);
    height: 28px;
    border-radius: 999px;
    background:
      linear-gradient(120deg, rgba(0, 182, 255, 0.22), rgba(255, 95, 134, 0.24));
    border: 1px solid color-mix(in srgb, var(--c-accent) 45%, var(--c-border) 55%);
    box-shadow:
      0 8px 16px -14px var(--c-shadow),
      0 0 20px -14px var(--c-glow);
    transition: transform 0.38s var(--ease-out-expo), background 0.35s;
  }

  :root[data-theme='night'] .theme-toggle__thumb {
    transform: translateX(63px);
    background:
      linear-gradient(120deg, rgba(103, 215, 255, 0.18), rgba(255, 158, 195, 0.28));
  }

  :root[data-theme='night'] .theme-toggle__label--day {
    opacity: 0.72;
    color: var(--c-text-muted);
  }

  :root[data-theme='night'] .theme-toggle__label--night {
    color: var(--c-text);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .theme-toggle {
      width: 128px;
      height: 34px;
    }

    .theme-toggle__thumb {
      height: 26px;
    }

    :root[data-theme='night'] .theme-toggle__thumb {
      transform: translateX(59px);
    }
  }
</style>
