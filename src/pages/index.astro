---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/withBase';
import { getCollection } from 'astro:content';
import WorkCard from '@/components/WorkCard.astro';

const visibleWorkIds = new Set(['bimangrasp', 'synpoldex']);
const works = (await getCollection('works'))
  .filter((work) => visibleWorkIds.has(work.id))
  .sort((a, b) => b.data.year - a.data.year);
const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const featuredWork = works[0];
const featuredPost = posts[0];

const postNotes: Record<string, string> = {
  formal_structures_of_complex_networks:
    'Complex networks, Curry-Howard, and formal structure.',
  'the-anthropomorphism-paradox':
    'Anthropomorphic priors, body schema, and embodied AI.',
};

function getPostNote(id: string) {
  return postNotes[id] ?? 'Notes from research and travel.';
}

function formatDate(date: string, locale: string) {
  return new Date(date).toLocaleDateString(locale, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="来日方長">
  <section class="hero container">
    <div class="hero__frame" data-reveal>
      <span class="section-marker section-marker--hero" aria-hidden="true">01</span>
      <div class="hero__copy">
        <p class="hero__name">Yanming Shao</p>

        <p class="hero__lede hero__lede--dispatch" data-lang-en-block>
          <span class="hero__dispatch-label">Pacific Time / Weather</span>
          <span id="hero-dispatch-en">Pacific Time --:--. San Francisco: --°C, low cloud, wind -- km/h.</span>
        </p>
        <p class="hero__lede hero__lede--dispatch" data-lang-zh-block>
          <span class="hero__dispatch-label">太平洋时间 / 天气</span>
          <span id="hero-dispatch-zh">太平洋时间 --:--。旧金山：--°C，低云，风速 -- km/h。</span>
        </p>
        <p class="hero__lede hero__lede--dispatch" data-lang-ja-block>
          <span class="hero__dispatch-label">太平洋時間 / 天気</span>
          <span id="hero-dispatch-ja">太平洋時間 --:--。サンフランシスコ：--°C、低い雲、風速 -- km/h。</span>
        </p>

        <nav class="hero__routes" aria-label="Primary">
          <a href={withBase('/works')} class="hero__route">
            <span data-lang-en>Works</span>
            <span data-lang-zh>作品</span>
            <span data-lang-ja>作品集</span>
          </a>
          <a href={withBase('/travelogue')} class="hero__route">
            <span data-lang-en>Travelogue</span>
            <span data-lang-zh>游记</span>
            <span data-lang-ja>旅行記</span>
          </a>
          <a href={withBase('/about')} class="hero__route">
            <span data-lang-en>About</span>
            <span data-lang-zh>关于</span>
            <span data-lang-ja>概要</span>
          </a>
        </nav>

        <div class="hero__poetry">
          <p class="hero__poem hero__poem--calligraphy">醉來信手兩三行，醒後卻書書不得</p>
          <p class="hero__poem-meta">
            <span data-lang-en>Huai Su, <cite>Autobiography</cite> (自叙帖)</span>
            <span data-lang-zh>怀素《自叙帖》</span>
            <span data-lang-ja>懐素『自叙帖』</span>
          </p>
        </div>

        <div class="hero__notes">
          <div class="hero__note">
            <span class="hero__note-label">
            <span data-lang-en>Research</span>
            <span data-lang-zh>研究</span>
            <span data-lang-ja>研究</span>
          </span>
            <p data-lang-en-block>Current focus: dexterous hands, bimanual manipulation, and data for embodied agents.</p>
            <p data-lang-zh-block>现在主要做灵巧手、双手操作，以及给具身智能用的数据生成。</p>
            <p data-lang-ja-block>現在の関心は、巧緻なロボットハンド、双手操作、そして具身エージェントのためのデータです。</p>
          </div>

          <div class="hero__note">
            <span class="hero__note-label">
            <span data-lang-en><span class="hero__note-label-accent">M.S.</span> 2026 / Research outlook</span>
            <span data-lang-zh><span class="hero__note-label-accent">硕士</span> 2026 / 研究方向</span>
            <span data-lang-ja><span class="hero__note-label-accent">修士</span> 2026 / 研究観</span>
          </span>
            <p data-lang-en-block>M.S. expected in 2026. He values the way research can move both industry and human understanding forward.</p>
            <p data-lang-zh-block>2026 年硕士毕业。珍视科研探索对产业和人类认知的推动作用。</p>
            <p data-lang-ja-block>2026年に修士修了予定です。研究の探究が産業と人間の認識を前に進める力になることを大切にしています。</p>
          </div>
        </div>
      </div>

      <div class="hero__visual" data-tilt data-tilt-limit="4">
        <div class="hero__board">
          <span class="hero__thread hero__thread--one" aria-hidden="true"></span>
          <span class="hero__thread hero__thread--two" aria-hidden="true"></span>
          <span class="hero__thread hero__thread--three" aria-hidden="true"></span>

          <article class="evidence evidence--painting">
            <span class="evidence__pin" aria-hidden="true"></span>
            <img
              src={withBase('/art/hero-night.png')}
              alt=""
              class="evidence__photo"
              loading="eager"
              decoding="async"
              aria-hidden="true"
            />
            <div class="evidence__meta">
              <span class="evidence__tag">
                <span data-lang-en>Painting</span>
                <span data-lang-zh>画面</span>
                <span data-lang-ja>絵</span>
              </span>
              <p data-lang-en-block>Selected artwork.</p>
              <p data-lang-zh-block>一张选的画。</p>
              <p data-lang-ja-block>掲載した絵です。</p>
            </div>
          </article>

          {featuredWork && (
            <a href={withBase(`/works/${featuredWork.id}`)} class="evidence evidence--work">
              <span class="evidence__pin" aria-hidden="true"></span>
              <img
                src={withBase(featuredWork.data.thumbnail)}
                alt={featuredWork.data.title}
                class="evidence__photo"
                loading="lazy"
              />
              <div class="evidence__meta">
                <span class="evidence__tag">
                  <span data-lang-en>Current Work</span>
                  <span data-lang-zh>最近论文</span>
                  <span data-lang-ja>現在の仕事</span>
                </span>
                <p>{featuredWork.data.title}</p>
              </div>
            </a>
          )}

          {featuredPost && (
            <a href={withBase(`/travelogue/${featuredPost.id}`)} class="evidence evidence--travelogue">
              <span class="evidence__pin" aria-hidden="true"></span>
              {featuredPost.data.thumbnail && (
                <img
                  src={withBase(featuredPost.data.thumbnail)}
                  alt={featuredPost.data.title}
                  class="evidence__photo evidence__photo--travelogue"
                  loading="lazy"
                />
              )}
              <div class="evidence__meta">
                <span class="evidence__tag evidence__tag--dark">Travelogue</span>
                <p>{featuredPost.data.title}</p>
                <span class="evidence__caption">{getPostNote(featuredPost.id)}</span>
              </div>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="selected container" data-reveal>
    <div class="selected__header">
      <span class="section-marker section-marker--selected" aria-hidden="true">02</span>
      <h2>
        <span data-lang-en>Works</span>
        <span data-lang-zh>作品</span>
        <span data-lang-ja>作品集</span>
      </h2>
      <a href={withBase('/works')} class="selected__see-all">
        <span data-lang-en>All works</span>
        <span data-lang-zh>全部作品</span>
        <span data-lang-ja>すべての作品</span>
      </a>
    </div>

    <div class="grid-2">
      {works.map((work) => (
        <WorkCard
          slug={work.id}
          title={work.data.title}
          description={work.data.description}
          thumbnail={work.data.thumbnail}
          category={work.data.category}
          year={work.data.year}
          metrics={[]}
        />
      ))}
    </div>
  </section>

  {posts.length > 0 && (
    <section class="writing container" data-reveal>
      <div class="writing__header">
        <span class="section-marker section-marker--selected" aria-hidden="true">03</span>
        <div class="writing__heading">
          <h2>
          <span data-lang-en>Travelogue</span>
          <span data-lang-zh>游记</span>
          <span data-lang-ja>旅行記</span>
          </h2>
          <p class="writing__subtitle">Research notes and travel notes.</p>
        </div>
        <a href={withBase('/travelogue')} class="selected__see-all">
          <span data-lang-en>All travelogue</span>
          <span data-lang-zh>全部游记</span>
          <span data-lang-ja>すべての旅行記</span>
        </a>
      </div>

      <div class="writing__grid">
        {posts.map((post) => {
          const note = getPostNote(post.id);
          return (
            <a href={withBase(`/travelogue/${post.id}`)} class="writing-card">
              {post.data.thumbnail && (
                <div class="writing-card__thumb-wrap">
                  <img
                    src={withBase(post.data.thumbnail)}
                    alt={post.data.title}
                    class="writing-card__thumb"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="writing-card__body">
                <span class="writing-card__date">
                  <span data-lang-en>{formatDate(post.data.date, 'en-US')}</span>
                  <span data-lang-zh>{formatDate(post.data.date, 'zh-CN')}</span>
                  <span data-lang-ja>{formatDate(post.data.date, 'ja-JP')}</span>
                </span>
                <h3 class="writing-card__title">{post.data.title}</h3>
                <p class="writing-card__excerpt">{note}</p>
                <div class="writing-card__meta">
                  <span class="writing-card__tag">Travelogue</span>
                  <span class="writing-card__arrow">&rarr;</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>

<script is:inline>
  function initHeroDispatch() {
    const targetEn = document.getElementById('hero-dispatch-en');
    const targetZh = document.getElementById('hero-dispatch-zh');
    const targetJa = document.getElementById('hero-dispatch-ja');
    if (!targetEn || !targetZh || !targetJa) return;

    if (window.__opendexHeroDispatchInterval) {
      clearInterval(window.__opendexHeroDispatchInterval);
    }

    const weatherText = {
      en: 'low cloud',
      zh: '低云',
      ja: '低い雲',
    };

    function formatPacificTime() {
      return new Intl.DateTimeFormat('en-GB', {
        timeZone: 'America/Los_Angeles',
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      }).format(new Date());
    }

    function describeWeather(code, lang, isDay) {
      if (code === 0) {
        return lang === 'zh'
          ? (isDay ? '天色放晴' : '天色清朗')
          : lang === 'ja'
            ? (isDay ? '晴れ' : '夜気は澄んでいる')
            : (isDay ? 'clear sky' : 'clear night');
      }
      if ([1, 2].includes(code)) {
        return lang === 'zh'
          ? '薄云未散'
          : lang === 'ja'
            ? '薄い雲'
            : 'thin cloud';
      }
      if (code === 3) {
        return lang === 'zh'
          ? '云层很重'
          : lang === 'ja'
            ? '厚い雲'
            : 'heavy cloud';
      }
      if ([45, 48].includes(code)) {
        return lang === 'zh'
          ? '有雾'
          : lang === 'ja'
            ? '霧'
            : 'fog';
      }
      if ([51, 53, 55, 56, 57].includes(code)) {
        return lang === 'zh'
          ? '细雨'
          : lang === 'ja'
            ? '霧雨'
            : 'drizzle';
      }
      if ([61, 63, 65, 66, 67, 80, 81, 82].includes(code)) {
        return lang === 'zh'
          ? '下雨'
          : lang === 'ja'
            ? '雨'
            : 'rain';
      }
      if ([71, 73, 75, 77, 85, 86].includes(code)) {
        return lang === 'zh'
          ? '有雪'
          : lang === 'ja'
            ? '雪'
            : 'snow';
      }
      if ([95, 96, 99].includes(code)) {
        return lang === 'zh'
          ? '雷暴'
          : lang === 'ja'
            ? '雷'
            : 'thunder';
      }
      return lang === 'zh'
        ? '天气不明'
        : lang === 'ja'
          ? '天気不明'
          : 'uncertain weather';
    }

    function render() {
      const time = formatPacificTime();
      const temp = typeof weatherText.temp === 'number' ? `${Math.round(weatherText.temp)}°C` : '??°C';
      const wind = typeof weatherText.wind === 'number' ? `${Math.round(weatherText.wind)} km/h` : '-- km/h';
      targetEn.textContent = `Pacific Time ${time}. San Francisco: ${temp}, ${weatherText.en}, wind ${wind}.`;
      targetZh.textContent = `太平洋时间 ${time}。旧金山：${temp}，${weatherText.zh}，风速 ${wind}。`;
      targetJa.textContent = `太平洋時間 ${time}。サンフランシスコ：${temp}、${weatherText.ja}、風速 ${wind}。`;
    }

    render();

    fetch('https://api.open-meteo.com/v1/forecast?latitude=37.7749&longitude=-122.4194&current=temperature_2m,weather_code,wind_speed_10m,is_day&timezone=America%2FLos_Angeles')
      .then((response) => response.ok ? response.json() : Promise.reject(new Error('weather unavailable')))
      .then((data) => {
        const current = data && data.current ? data.current : null;
        if (!current) return;
        weatherText.temp = current.temperature_2m;
        weatherText.wind = current.wind_speed_10m;
        weatherText.en = describeWeather(current.weather_code, 'en', current.is_day === 1);
        weatherText.zh = describeWeather(current.weather_code, 'zh', current.is_day === 1);
        weatherText.ja = describeWeather(current.weather_code, 'ja', current.is_day === 1);
        render();
      })
      .catch(() => {
        render();
      });

    window.__opendexHeroDispatchInterval = window.setInterval(render, 60000);
  }

  initHeroDispatch();
  document.addEventListener('astro:page-load', initHeroDispatch);
</script>

<style>
  .hero {
    padding-top: clamp(4.5rem, 12vh, 7rem);
    padding-bottom: 3rem;
  }

  .hero__frame {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
    gap: clamp(1.4rem, 3vw, 2.8rem);
    align-items: center;
    position: relative;
    padding: clamp(1rem, 2vw, 1.4rem);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(18, 18, 20, 0.82), rgba(24, 25, 29, 0.9));
    box-shadow: 0 34px 60px -46px rgba(0, 0, 0, 0.75);
    overflow: hidden;
  }

  .hero__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent),
      url('/art/6vcr_3.png') center / cover no-repeat;
    opacity: 0.12;
    mix-blend-mode: screen;
  }

  .section-marker {
    position: absolute;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4rem;
    height: 3rem;
    padding: 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;
    color: #efe4d8;
    background:
      linear-gradient(180deg, rgba(122, 67, 42, 0.96), rgba(80, 41, 29, 0.96));
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 12px 20px -14px rgba(0, 0, 0, 0.75),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .section-marker::after {
    content: '';
    position: absolute;
    inset: auto 0 -0.75rem;
    margin: 0 auto;
    width: 0;
    height: 0;
    border-left: 0.8rem solid transparent;
    border-right: 0.8rem solid transparent;
    border-top: 0.8rem solid rgba(80, 41, 29, 0.96);
  }

  .section-marker--hero {
    top: 1rem;
    left: 1rem;
  }

  .section-marker--selected {
    position: relative;
    top: auto;
    left: auto;
    margin-right: 0.65rem;
    vertical-align: middle;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    position: relative;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    border: 1px solid rgba(75, 68, 58, 0.26);
    background:
      linear-gradient(180deg, rgba(242, 235, 224, 0.98), rgba(231, 223, 212, 0.94));
    box-shadow:
      0 24px 40px -34px rgba(0, 0, 0, 0.45),
      0 1px 0 rgba(255, 255, 255, 0.55) inset;
    color: #231d19;
    transform: rotate(-1.25deg);
  }

  .hero__copy::before,
  .hero__copy::after {
    content: '';
    position: absolute;
    width: 2.9rem;
    height: 0.85rem;
    background: rgba(214, 203, 185, 0.6);
    border: 1px solid rgba(103, 91, 77, 0.12);
    box-shadow: 0 6px 8px -8px rgba(0, 0, 0, 0.55);
  }

  .hero__copy::before {
    top: -0.35rem;
    left: 1.4rem;
    transform: rotate(-8deg);
  }

  .hero__copy::after {
    top: -0.2rem;
    right: 1.7rem;
    transform: rotate(7deg);
  }

  .hero__name {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, #3f6c75 40%, #7f302d 60%);
  }

  .hero__lede {
    font-size: clamp(1.02rem, 1.45vw, 1.16rem);
    line-height: 1.85;
    color: #4f392f;
    max-width: 38ch;
  }

  .hero__lede--dispatch {
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
  }

  .hero__dispatch-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, #3f6c75 42%, #8f342c 58%);
  }

  .hero__routes {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
    padding-top: 0.2rem;
  }

  .hero__route {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #675244;
    padding-bottom: 0.2rem;
    border-bottom: 1px solid transparent;
    transition:
      color 0.25s ease,
      border-color 0.25s ease,
      transform 0.25s ease;
  }

  .hero__route:hover {
    color: #7a372d;
    border-color: rgba(131, 49, 45, 0.4);
    transform: translateX(2px);
  }

  .hero__poetry {
    margin-top: 0.25rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(76, 67, 58, 0.22);
  }

  .hero__poem {
    max-width: 12ch;
  }

  .hero__poem--calligraphy {
    font-family: var(--font-calligraphy);
    font-size: clamp(2.4rem, 5.3vw, 4.8rem);
    line-height: 1.28;
    letter-spacing: 0.08em;
    color: #111;
    text-wrap: pretty;
  }

  .hero__poem-meta {
    margin-top: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: #7a5a4a;
  }

  .hero__notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 0.2rem;
  }

  .hero__note {
    padding: 1rem 1rem 0.95rem;
    border: 1px solid rgba(76, 67, 58, 0.16);
    background:
      linear-gradient(180deg, rgba(252, 247, 240, 0.76), rgba(234, 227, 217, 0.74));
    box-shadow:
      0 14px 24px -30px rgba(0, 0, 0, 0.3),
      0 1px 0 rgba(255, 255, 255, 0.45) inset;
  }

  .hero__note-label {
    display: inline-flex;
    margin-bottom: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #804033;
  }

  .hero__note-label-accent {
    color: #b38a4a;
  }

  .hero__note p {
    font-size: 0.86rem;
    line-height: 1.65;
    color: #5f4f43;
    max-width: 28ch;
  }

  .hero__visual {
    min-width: 0;
  }

  .hero__board {
    position: relative;
    min-height: clamp(340px, 58vw, 680px);
    border-radius: 26px;
    overflow: hidden;
    border: 1px solid rgba(255, 248, 240, 0.08);
    background:
      radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.04), transparent 24%),
      radial-gradient(circle at 72% 64%, rgba(255, 255, 255, 0.03), transparent 26%),
      linear-gradient(180deg, rgba(20, 19, 22, 0.96), rgba(27, 29, 34, 0.96));
    box-shadow:
      0 34px 70px -42px rgba(0, 0, 0, 0.6),
      0 1px 0 rgba(255, 255, 255, 0.06) inset;
  }

  .hero__board::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(0deg, transparent 0%, rgba(255, 255, 255, 0.03) 100%),
      url('/art/hero-winter.png') center / cover no-repeat;
    opacity: 0.14;
    mix-blend-mode: screen;
  }

  .hero__board::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.14), transparent 20%),
      radial-gradient(circle at 82% 74%, rgba(255, 255, 255, 0.08), transparent 18%);
    mix-blend-mode: screen;
    opacity: 0.18;
  }

  .hero__thread {
    position: absolute;
    height: 2px;
    background: linear-gradient(90deg, rgba(143, 34, 29, 0.3), rgba(181, 54, 44, 0.92), rgba(143, 34, 29, 0.3));
    box-shadow: 0 0 6px rgba(181, 54, 44, 0.28);
    transform-origin: left center;
    z-index: 0;
  }

  .hero__thread--one {
    left: 17%;
    top: 28%;
    width: 48%;
    transform: rotate(19deg);
  }

  .hero__thread--two {
    left: 48%;
    top: 34%;
    width: 28%;
    transform: rotate(102deg);
  }

  .hero__thread--three {
    left: 31%;
    top: 66%;
    width: 38%;
