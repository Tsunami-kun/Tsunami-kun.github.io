---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '@/lib/withBase';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, tags = [] } = post.data;

const formattedEn = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedZh = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedJa = new Date(date).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${title} — Yanming Shao`}
  defaultLang="zh"
  langStorageKey="opendex-travelogue-lang"
>
  <div class="progress-bar" id="progress-bar" aria-hidden="true">
    <div class="progress-bar__fill" id="progress-fill"></div>
  </div>

  <article class="post container" id="article">
    <header class="post__header">
      <span class="post__date">
        <span data-lang-en>{formattedEn}</span>
        <span data-lang-zh>{formattedZh}</span>
        <span data-lang-ja>{formattedJa}</span>
      </span>
      <h1 class="post__title">{title}</h1>
      {tags.length > 0 && (
        <div class="post__tags">
          {tags.map((tag: string) => (
            <span class="post__tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <section class="post__sheet">
      <div class="post__lang-note">
        <span data-lang-en>Article language</span>
        <span data-lang-zh>文章语言</span>
        <span data-lang-ja>記事の言語</span>
      </div>

      <div class="prose post__prose post__prose--pending" id="post-prose">
        <Content />
      </div>
    </section>

    <div class="post__end">
      <span class="post__end-line"></span>
      <span class="post__end-label"><span data-lang-en>End</span><span data-lang-zh>终</span><span data-lang-ja>了</span></span>
      <span class="post__end-line"></span>
    </div>

    <a href={withBase('/travelogue')} class="post__back">&larr; <span data-lang-en>Travelogue</span><span data-lang-zh>游记</span><span data-lang-ja>旅行記</span></a>
  </article>

  <script is:inline>
    function initPostLanguageGroups() {
      const prose = document.getElementById('post-prose');
      if (!prose || prose.dataset.grouped === 'true') return;

      const nodes = Array.from(prose.children);
      const fragment = document.createDocumentFragment();
      let currentGroup = null;
      const markerMap = {
        zh: '中文',
        en: 'EN',
        ja: '日本語',
      };

      function detectLangMarker(element) {
        if (!element || element.tagName !== 'P') return null;
        const text = (element.textContent || '').replace(/\s+/g, ' ').trim();
        if (/^中文(?:\s*\|)?(?:\s|$)/.test(text)) return 'zh';
        if (/^EN(?:\s*\|)?(?:\s|$)/.test(text)) return 'en';
        if (/^日本語(?:\s*\|)?(?:\s|$)/.test(text)) return 'ja';
        return null;
      }

      function stripLangMarker(element, lang) {
        const clone = element.cloneNode(true);
        const markerLabel = markerMap[lang];

        while (clone.firstChild) {
          const firstChild = clone.firstChild;

          if (
            firstChild.nodeType === Node.ELEMENT_NODE &&
            firstChild.tagName === 'STRONG' &&
            (firstChild.textContent || '').replace(/\s+/g, ' ').trim() === markerLabel
          ) {
            clone.removeChild(firstChild);
            continue;
          }

          if (firstChild.nodeType === Node.TEXT_NODE) {
            const cleanedText = (firstChild.textContent || '').replace(/^\s*\|\s*/, '').replace(/^\s+/, '');

            if (!cleanedText) {
              clone.removeChild(firstChild);
              continue;
            }

            firstChild.textContent = cleanedText;
          }

          break;
        }

        return clone.textContent && clone.textContent.trim() ? clone : null;
      }

      nodes.forEach((node) => {
        const lang = detectLangMarker(node);
        const isBoundary = /^H[1-6]$/.test(node.tagName) || node.tagName === 'HR';

        if (lang) {
          currentGroup = document.createElement('div');
          currentGroup.className = 'post__lang-group';
          currentGroup.dataset.langGroup = lang;
          fragment.appendChild(currentGroup);

          const cleanedNode = stripLangMarker(node, lang);
          if (cleanedNode) {
            currentGroup.appendChild(cleanedNode);
          }

          return;
        }

        if (isBoundary) {
          currentGroup = null;
          fragment.appendChild(node);
          return;
        }

        if (currentGroup) {
          currentGroup.appendChild(node);
          return;
        }

        fragment.appendChild(node);
      });

      prose.replaceChildren(fragment);
      prose.dataset.grouped = 'true';
      prose.classList.remove('post__prose--pending');
    }

    function initProgress() {
      const fill = document.getElementById('progress-fill');
      const article = document.getElementById('article');
      if (!fill || !article) return;

      let ticking = false;

      function updateProgress() {
        const rect = article.getBoundingClientRect();
        const articleTop = rect.top + window.scrollY;
        const articleHeight = rect.height;
        const viewportHeight = window.innerHeight;

        const scrolled = window.scrollY - articleTop;
        const total = articleHeight - viewportHeight;

        let progress = 0;
        if (total > 0) {
          progress = Math.min(Math.max(scrolled / total, 0), 1);
        }

        fill.style.transform = `scaleX(${progress})`;
        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateProgress);
          ticking = true;
        }
      }, { passive: true });

      updateProgress();
    }

    initPostLanguageGroups();
    initProgress();
    document.addEventListener('astro:page-load', initPostLanguageGroups);
    document.addEventListener('astro:page-load', initProgress);
  </script>
</BaseLayout>

<style>
  .post {
    --post-brass: #a68558;
    --post-copper: #8a5436;
    --post-oxide: #33585c;
    --post-wine: #6e2d2b;
    --post-ink: #2b1f16;
    --post-sepia: #4a382b;
    --post-paper-top: rgba(245, 233, 213, 0.98);
    --post-paper-mid: rgba(234, 219, 195, 0.97);
    --post-paper-bottom: rgba(219, 199, 170, 0.96);
  }

  .progress-bar {
    position: fixed;
    top: 3.75rem;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 99;
    background: rgba(18, 44, 86, 0.1);
  }

  .progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--c-accent), var(--c-accent-2));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.1s linear;
    will-change: transform;
    box-shadow: 0 0 14px rgba(0, 182, 255, 0.4);
  }

  .post {
    padding-top: clamp(3.2rem, 8vh, 6.2rem);
  }

  .post__header {
    margin-bottom: 2rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid rgba(188, 156, 117, 0.18);
    position: relative;
  }

  .post__date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--post-brass) 68%, #f6e8d5 32%);
    display: block;
    margin-bottom: 1rem;
  }

  .post__title {
    margin-bottom: 1rem;
    max-width: 18ch;
    color: #f7ecda;
    text-shadow: 0 10px 28px rgba(21, 16, 11, 0.22);
  }

  .post__tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post__tag {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: #f3e2cf;
    background: linear-gradient(120deg, rgba(148, 105, 65, 0.26), rgba(79, 106, 112, 0.22));
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(196, 159, 114, 0.24);
  }

  .post__sheet {
    position: relative;
    padding: 1.35rem clamp(1rem, 2.5vw, 1.7rem) 1.6rem;
    border: 1px solid rgba(177, 139, 96, 0.22);
    background:
      linear-gradient(180deg, rgba(23, 19, 17, 0.88), rgba(16, 21, 24, 0.9)),
      radial-gradient(circle at top left, rgba(164, 121, 78, 0.1), transparent 40%);
    box-shadow:
      0 34px 56px -48px rgba(0, 0, 0, 0.82),
      0 0 0 1px rgba(76, 56, 39, 0.22) inset;
    overflow: hidden;
  }

  .post__sheet::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 244, 228, 0.04), transparent 24%),
      repeating-linear-gradient(90deg, rgba(255, 239, 214, 0.02) 0 1px, transparent 1px 34px),
      url('/art/reference-night.jpg') center / cover no-repeat;
    opacity: 0.12;
    mix-blend-mode: soft-light;
    pointer-events: none;
  }

  .post__lang-note {
    position: relative;
    z-index: 1;
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.28rem 0.64rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2a1e16;
    background: linear-gradient(180deg, rgba(202, 167, 118, 0.92), rgba(162, 121, 79, 0.9));
    border: 1px solid rgba(106, 73, 45, 0.4);
    box-shadow: 0 12px 18px -16px rgba(0, 0, 0, 0.65);
  }

  .post__prose {
    position: relative;
    z-index: 1;
    padding: 1.45rem clamp(1rem, 3vw, 2rem) 1.8rem;
    background:
      linear-gradient(180deg, var(--post-paper-top), var(--post-paper-mid) 58%, var(--post-paper-bottom));
    border: 1px solid rgba(115, 86, 57, 0.38);
    box-shadow:
      0 22px 34px -30px rgba(0, 0, 0, 0.7),
      0 1px 0 rgba(255, 249, 236, 0.44) inset,
      0 0 0 1px rgba(255, 243, 220, 0.16) inset;
    overflow: hidden;
  }

  .post__prose::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.24), transparent 18%),
      repeating-linear-gradient(0deg, rgba(114, 84, 56, 0.03) 0 1px, transparent 1px 32px);
    pointer-events: none;
  }

  .post__prose--pending > * {
    opacity: 0;
  }

  :global(.post__lang-group) {
    display: none;
  }

  :global(:root[data-lang='en'] .post__lang-group[data-lang-group='en']),
  :global(:root[data-lang='zh'] .post__lang-group[data-lang-group='zh']),
  :global(:root[data-lang='ja'] .post__lang-group[data-lang-group='ja']) {
    display: block;
  }

  :global(.post__lang-group > :first-child) {
    margin-top: 0;
  }

  .post :global(.prose h2),
  .post :global(.prose h3) {
    color: var(--post-wine);
    letter-spacing: 0.02em;
    border-bottom: 1px solid rgba(137, 100, 67, 0.18);
    padding-bottom: 0.35rem;
  }

  .post :global(.prose p),
  .post :global(.prose li) {
    color: var(--post-sepia);
    line-height: 1.95;
    text-wrap: pretty;
  }

  .post :global(.prose p:first-of-type) {
    color: var(--post-ink);
  }

  .post :global(.prose strong) {
    color: var(--post-wine);
  }

  .post :global(.prose a) {
    color: var(--post-oxide);
    text-decoration-color: rgba(51, 88, 92, 0.35);
  }

  .post :global(.prose li::marker) {
    color: var(--post-copper);
  }

  .post :global(.prose blockquote) {
    border-left-color: var(--post-brass);
    color: #4b382c;
    background: linear-gradient(90deg, rgba(151, 118, 75, 0.12), rgba(255, 255, 255, 0));
    padding: 0.6rem 0 0.6rem 1.2rem;
  }

  .post :global(.prose code) {
    color: var(--post-wine);
    background: rgba(110, 78, 51, 0.08);
  }

  .post__end {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    color: var(--c-text-muted);
  }

  .post__end-line {
    flex: 1;
    height: 1px;
    background: var(--c-border);
  }

  .post__end-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .post__back {
    display: inline-block;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--c-text-muted);
    transition: color 0.2s, transform 0.2s;
  }

  .post__back:hover {
    color: color-mix(in srgb, var(--c-accent) 72%, var(--c-text) 28%);
    transform: translateX(-2px);
  }

  @media (max-width: 640px) {
    .progress-bar {
      top: 6.2rem;
    }

    .post__sheet {
      padding: 0.95rem;
    }

    .post__prose {
      padding: 1.15rem 0.95rem 1.3rem;
    }

    .post__end {
      gap: 0.6rem;
    }

    .post__lang-note {
      font-size: 0.62rem;
    }
  }
</style>
