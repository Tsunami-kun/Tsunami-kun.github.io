---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '@/lib/withBase';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Travelogue — Yanming Shao" defaultLang="zh" langStorageKey="opendex-travelogue-lang">
  <section class="travelogue container">
    <div class="travelogue__visual">
      <!-- Artwork by 6VCR (Eugenia Goncharova) — https://6vcr.com -->
      <img
        src={withBase('/art/hero-winter.png')}
        alt=""
        class="travelogue__visual-img travelogue__visual-img--day"
        aria-hidden="true"
      />
      <img
        src={withBase('/art/hero-night.png')}
        alt=""
        class="travelogue__visual-img travelogue__visual-img--night"
        aria-hidden="true"
      />
      <div class="travelogue__visual-atmosphere" aria-hidden="true"></div>
      <div class="travelogue__visual-note">
        <span><span data-lang-en>Travel Journal</span><span data-lang-zh>旅行日志</span><span data-lang-ja>旅行日誌</span></span>
        <p data-lang-en-block>Dispatches from conferences, field visits, and the road between labs.</p>
        <p data-lang-zh-block>来自学术会议、实地考察和实验室之间旅途的记录。</p>
        <p data-lang-ja-block>学会、フィールド訪問、研究室間の道中からの記録。</p>
      </div>
    </div>
    <header class="travelogue__header">
      <h1><span data-lang-en>Travelogue</span><span data-lang-zh>游记</span><span data-lang-ja>旅行記</span></h1>
      <p class="travelogue__subtitle" data-lang-en-block>Notes, dispatches, and reflections from the road.</p>
      <p class="travelogue__subtitle" data-lang-zh-block>旅途中的笔记、报道和思考。</p>
      <p class="travelogue__subtitle" data-lang-ja-block>旅路からのノート、報告、そして省察。</p>
    </header>
    <div class="travelogue__grid">
      {posts.map((post) => (
        <a href={withBase(`/travelogue/${post.id}`)} class="post-card">
          {post.data.thumbnail && (
            <div class="post-card__thumb-wrap">
              <img
                src={withBase(post.data.thumbnail)}
                alt={post.data.title}
                class="post-card__thumb"
                loading="lazy"
              />
            </div>
          )}
          <div class="post-card__body">
            <span class="post-card__date">{formatDate(post.data.date)}</span>
            <h3 class="post-card__title">{post.data.title}</h3>
            {post.data.excerpt && (
              <p class="post-card__excerpt">{post.data.excerpt}</p>
            )}
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-card__tags">
                {post.data.tags.map((tag: string) => (
                  <span class="post-card__tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <div class="post-card__arrow">&rarr;</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .travelogue {
    padding-top: clamp(3.2rem, 8vh, 6.2rem);
  }

  .travelogue__visual {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--c-border);
    min-height: clamp(180px, 30vw, 250px);
    margin-bottom: 1.6rem;
    box-shadow:
      0 20px 36px -28px var(--c-shadow),
      0 1px 0 var(--surface-highlight) inset;
  }

  .travelogue__visual-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--theme-switch-ms) var(--theme-switch-ease), transform var(--theme-switch-ms) var(--theme-switch-ease);
  }

  .travelogue__visual-img--night {
    opacity: 0;
    transform: scale(1.04);
  }

  :root[data-theme='night'] .travelogue__visual-img--day {
    opacity: 0;
    transform: scale(1.03);
  }

  :root[data-theme='night'] .travelogue__visual-img--night {
    opacity: 1;
    transform: scale(1);
  }

  .travelogue__visual-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, transparent 30%, rgba(19, 32, 61, 0.18) 60%, rgba(19, 32, 61, 0.42) 100%);
    mix-blend-mode: multiply;
    pointer-events: none;
    transition: background var(--theme-switch-ms) var(--theme-switch-ease);
  }

  :root[data-theme='night'] .travelogue__visual-atmosphere {
    background:
      linear-gradient(180deg, transparent 25%, rgba(103, 215, 255, 0.08) 55%, rgba(6, 16, 34, 0.55) 100%);
    mix-blend-mode: screen;
  }

  .travelogue__visual-note {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 2;
    padding: 0.65rem 0.85rem;
    border-radius: 12px;
    border: 1px solid var(--c-border);
    background:
      linear-gradient(120deg, var(--surface-glass-a), var(--surface-glass-b));
    backdrop-filter: blur(6px);
    max-width: min(74vw, 460px);
  }

  .travelogue__visual-note span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--c-accent) 62%, var(--c-text) 38%);
  }

  .travelogue__visual-note p {
    font-size: 0.88rem;
    line-height: 1.4;
    margin-top: 0.2rem;
    color: var(--c-text);
  }

  .travelogue__header {
    margin-bottom: 2.2rem;
  }

  .travelogue__header h1 {
    margin-bottom: 0.35rem;
  }

  .travelogue__subtitle {
    color: var(--c-text-muted);
    font-size: 1rem;
    max-width: 52ch;
  }

  /* ─── Card Grid ─── */
  .travelogue__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--grid-gap);
  }

  @media (max-width: 480px) {
    .travelogue__visual {
      min-height: 160px;
      border-radius: 14px;
    }

    .travelogue__grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(165deg, var(--surface-glass-a), var(--surface-glass-b));
    border: 1px solid var(--c-border);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.35s, transform 0.35s var(--ease-out-expo), box-shadow 0.35s;
    position: relative;
    box-shadow:
      0 12px 26px -24px var(--c-shadow),
      0 2px 0 color-mix(in srgb, var(--surface-highlight) 80%, transparent) inset;
  }

  .post-card:hover {
    border-color: color-mix(in srgb, var(--c-accent) 52%, var(--c-border) 48%);
    transform: translateY(-6px);
    box-shadow:
      0 18px 35px -22px rgba(0, 182, 255, 0.35),
      0 2px 0 color-mix(in srgb, var(--surface-highlight) 86%, transparent) inset;
  }

  .post-card__thumb-wrap {
    aspect-ratio: 2 / 1;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0, 182, 255, 0.13), rgba(255, 95, 134, 0.12));
  }

  .post-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo), filter 0.6s var(--ease-out-expo);
  }

  .post-card:hover .post-card__thumb {
    transform: scale(1.055);
    filter: saturate(1.12) contrast(1.03);
  }

  .post-card__body {
    padding: 1.35rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-card__date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-text-muted);
    margin-bottom: 0.5rem;
  }

  .post-card__title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .post-card__excerpt {
    font-size: 0.88rem;
    color: var(--c-text-muted);
    line-height: 1.55;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .post-card__tag {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--c-text-muted);
    background: linear-gradient(120deg, rgba(0, 182, 255, 0.12), rgba(255, 95, 134, 0.1));
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--c-border);
  }

  .post-card__arrow {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--c-accent) 65%, var(--c-text) 35%);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.3s, transform 0.3s var(--ease-out-expo);
  }

  .post-card:hover .post-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
